{
  "name": "wikillm-api",
  "version": "0.1.0",
  "description": "HTTP API for wiki-llm folders, safe to run alongside Obsidian and sync tools.",
  "type": "module",
  "module": "src/index.ts",
  "scripts": {
    "dev": "bun run --watch src/index.ts",
    "start": "bun run src/index.ts",
    "start:node": "tsx src/index.node.ts",
    "test": "vitest",
    "test:run": "vitest run",
    "lint": "tsc --noEmit",
    "fmt": "prettier --write ."
  },
  "dependencies": {
    "@hono/node-server": "^1.13.8",
    "chokidar": "^4.0.3",
    "gray-matter": "^4.0.3",
    "hono": "^4.6.14",
    "pino": "^9.6.0",
    "ulidx": "^2.4.1",
    "zod": "^3.24.1"
  },
  "optionalDependencies": {
    "better-sqlite3": "^12.5.0",
    "ws": "^8.21.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/bun": "^1.3.14",
    "@types/node": "^22.10.5",
    "@types/ws": "^8.18.1",
    "autocannon": "^8.0.0",
    "prettier": "^3.4.2",
    "supertest": "^7.0.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "vitest": "^2.1.8"
  },
  "peerDependencies": {
    "typescript": "^5.7.3"
  },
  "engines": {
    "bun": ">=1.0.0",
    "node": ">=20.0.0"
  }
}

# Required
WIKI_ROOT=/path/to/your/wiki-llm-folder

# Server
PORT=3000
HOST=0.0.0.0

# Auth: comma-separated key:name pairs. Name becomes the source attribution.
API_KEYS="agent-codex:codex-key-xxx,user-luke:luke-key-yyy,clipper:clipper-key-zzz"

# Allow unauthenticated read access (default: true)
PUBLIC_READ=true

# SQLite cache/ledger path (default: ./wikillm-api.db)
DB_PATH=

# Logging: trace, debug, info, warn, error
LOG_LEVEL=info
